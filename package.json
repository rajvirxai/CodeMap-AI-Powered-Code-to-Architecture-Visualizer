{
  "name": "codemap-integrated",
  "version": "1.0.0",
  "description": "Integrated runner for CodeMap backend and frontend",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "backend": "node index.js",
    "frontend": "npm run dev --prefix frontend",
