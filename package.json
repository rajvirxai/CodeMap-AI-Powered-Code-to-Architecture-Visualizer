  "keywords": [
    "express",
    "multer",
    "adm-zip",
    "code-to-architecture",
    "concurrently"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "adm-zip": "^0.5.12",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "concurrently": "^8.2.2"
  }
}
